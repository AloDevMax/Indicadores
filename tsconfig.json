{
  "compilerOptions": {
    "jsx": "react-jsx", // <-- ESSA É A LINHA QUE FALTA
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": false,
    "outDir": "./dist",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false
  },
  "include": ["index.ts", "App.tsx", "server/**/*", "utils/**/*"], // Liste o que deve ser compilado
  "exclude": ["node_modules", "dist", "generated"]
}

  
