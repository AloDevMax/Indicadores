{
  "name": "labquest-sistema-de-qualidade-gamificado",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env scripts/dbPush.mjs && node --env-file=.env server/index.mjs",
    "db:push": "node --env-file=.env scripts/dbPush.mjs",
    "db:check": "node --env-file=.env scripts/verifyDb.mjs",
    "db:test": "node --env-file=.env scripts/testDbConnection.mjs",
    "db:diagnose": "node --env-file=.env scripts/diagnoseDb.mjs",
    "db:seed:labvw": "node --env-file=.env scripts/seedLabvwUsers.mjs",
    "build": "node scripts/build.mjs",
    "start": "node dist/server/index.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "busboy": "^1.6.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "lucide-react": "^1.16.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "0.18.5",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prisma": "^6.19.2",
    "typescript": "~5.8.2",
    "vite": "^6.4.1"
  }
}
