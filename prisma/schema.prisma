// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
  developer
}

enum BadgeTone {
  bronze
  silver
  gold
  loss_1
  loss_2
}

enum SubmissionStatus {
  pending
  approved
  rejected
}

enum ImportRowStatus {
  valid
  invalid
  imported
}

enum ImportRunStatus {
  pending
  completed
  failed
}

model Company {
  id               String           @id @db.Text
  name             String           @unique
  category         String?
  logo_url         String?
  created_at       DateTime         @default(now()) @db.Timestamp(6)
  productive_units ProductiveUnit[]
  users            User[]

  @@map("companies")
}

model ProductiveUnit {
  id         String   @id @db.Text
  company_id String   @db.Text
  name       String
  created_at DateTime @default(now()) @db.Timestamp(6)

  company Company @relation(fields: [company_id], references: [id])
  users   User[]

  @@unique([company_id, name])
  @@map("productive_units")
}

model User {
  id                 String   @id @default(uuid()) @db.Uuid
  email              String   @unique
  password_hash      String
  full_name          String
  avatar_url         String?
  role               Role
  company_id         String?  @db.Text
  productive_unit_id String?  @db.Text
  level              Int      @default(1)
  xp                 Int      @default(0)
  email_verified     Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamp(6)
  updated_at         DateTime @default(now()) @db.Timestamp(6)

  company               Company?             @relation(fields: [company_id], references: [id])
  productive_unit       ProductiveUnit?      @relation(fields: [productive_unit_id], references: [id])
  sessions              AuthSession[]
  user_badges           UserBadge[]
  awarded_badges        UserBadge[]          @relation("AwardedBy")
  submissions           BadgeSubmission[]    @relation("SubmissionUser")
  reviewed_submissions  BadgeSubmission[]    @relation("ReviewedBy")
  notifications         Notification[]
  badge_legend_settings BadgeLegendSetting[] @relation("LegendUpdatedBy")
  import_runs           ImportRun[]          @relation("ImportedBy")

  @@map("users")
}

model AuthSession {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  expires_at DateTime  @db.Timestamp(6)
  revoked_at DateTime? @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id])

  @@map("auth_sessions")
}

model Badge {
  id          String            @id @db.Text
  name        String            @unique
  description String
  category    String
  icon_name   String
  image_url   String?
  points      Int               @default(0)
  created_at  DateTime          @default(now()) @db.Timestamp(6)
  user_badges UserBadge[]
  submissions BadgeSubmission[]

  @@map("badges")
}

model BadgeLegendSetting {
  id         String   @id @default(uuid()) @db.Uuid
  bronze     String
  silver     String
  gold       String
  loss_1     String
  loss_2     String
  updated_by String?  @db.Uuid
  updated_at DateTime @default(now()) @db.Timestamp(6)

  updatedBy User? @relation("LegendUpdatedBy", fields: [updated_by], references: [id])

  @@map("badge_legend_settings")
}

model UserBadge {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  badge_id   String    @db.Text
  awarded_at DateTime  @default(now()) @db.Timestamp(6)
  awarded_by String?   @db.Uuid
  tone       BadgeTone

  user      User  @relation(fields: [user_id], references: [id])
  badge     Badge @relation(fields: [badge_id], references: [id])
  awardedBy User? @relation("AwardedBy", fields: [awarded_by], references: [id])

  @@map("user_badges")
}

model BadgeSubmission {
  id           String           @id @default(uuid()) @db.Uuid
  user_id      String           @db.Uuid
  badge_id     String           @db.Text
  proof_url    String?
  description  String?
  status       SubmissionStatus @default(pending)
  submitted_at DateTime         @default(now()) @db.Timestamp(6)
  reviewed_by  String?          @db.Uuid
  reviewed_at  DateTime?        @db.Timestamp(6)
  feedback     String?

  user       User  @relation("SubmissionUser", fields: [user_id], references: [id])
  badge      Badge @relation(fields: [badge_id], references: [id])
  reviewedBy User? @relation("ReviewedBy", fields: [reviewed_by], references: [id])

  @@map("badge_submissions")
}

model Notification {
  id      String   @id @default(uuid()) @db.Uuid
  user_id String   @db.Uuid
  title   String
  message String
  sent_at DateTime @default(now()) @db.Timestamp(6)
  read    Boolean  @default(false)

  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model ImportSource {
  id                     String      @id @db.Text
  name                   String      @unique
  description            String?
  company_column         String
  productive_unit_column String
  user_column            String
  badge_column           String
  tone_column            String      @default("marcacao")
  award_column           String      @default("premio")
  created_at             DateTime    @default(now()) @db.Timestamp(6)
  archived_at            DateTime?
  import_runs            ImportRun[]

  @@map("import_sources")
}

model ImportRun {
  id              String          @id @default(uuid()) @db.Uuid
  source_id       String?         @db.Text
  source_name     String
  imported_by     String?         @db.Uuid
  imported_at     DateTime        @default(now()) @db.Timestamp(6)
  status          ImportRunStatus @default(completed)
  matched_columns Json            @default("{}")
  summary         Json            @default("{}")

  source     ImportSource?  @relation(fields: [source_id], references: [id])
  importedBy User?          @relation("ImportedBy", fields: [imported_by], references: [id])
  rows       ImportRunRow[]

  @@map("import_runs")
}

model ImportRunRow {
  id                 String          @id @default(uuid()) @db.Uuid
  import_run_id      String          @db.Uuid
  row_number         Int
  raw_payload        Json
  normalized_payload Json?
  status             ImportRowStatus
  reason             String?

  import_run ImportRun @relation(fields: [import_run_id], references: [id])

  @@map("import_run_rows")
}
